  - m_Id: 76852223095758848
    m_Localized: "\u041F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C"
    m_Metadata:
      m_Items: []
  - m_Id: 76852223095758849
    m_Localized: "\u041F\u0435\u0440\u0435\u0437\u0430\u043F\u0443\u0441\u0442\u0438\u0442\u044C
      \u0432\u043E\u043B\u043D\u0443"
    m_Metadata:
      m_Items: []
  - m_Id: 88486973308821504
    m_Localized: "\u041F\u043E\u0434\u0434\u0435\u0440\u0436\u0430\u0442\u044C \u0430\u0432\u0442\u043E\u0440\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 88938520870281216
    m_Localized: "\u041F\u043E\u0436\u0435\u0440\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u044F"
    m_Metadata:
      m_Items: []
  - m_Id: 88938520903835649
    m_Localized: "USDC/Solana\n(\u043D\u0430\u0436\u043C\u0438\u0442\u0435, \u0447\u0442\u043E\u0431\u044B
      \u0441\u043A\u043E\u043F\u0438\u0440\u043E\u0432\u0430\u0442\u044C)"
    m_Metadata:
      m_Items: []
  - m_Id: 88938520903835650
    m_Localized: "\u041B\u043E\u043A\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u044F"
    m_Metadata:
      m_Items: []
  - m_Id: 88938520903835651
    m_Localized: "\u0412\u044B \u043C\u043E\u0436\u0435\u0442\u0435 \u043F\u043E\u043C\u043E\u0447\u044C,
      \u0441\u043E\u0437\u0434\u0430\u0432 \u0444\u0430\u043D\u0430\u0442\u0441\u043A\u0438\u0439
      \u043F\u0435\u0440\u0435\u0432\u043E\u0434 \u0434\u043B\u044F \u044F\u0437\u044B\u043A\u0430,
      \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u043A\u0430 \u043D\u0435
      \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0435\u0442\u0441\u044F!
      (\u0418\u043B\u0438 \u0443\u043B\u0443\u0447\u0448\u0438\u0432 \u043E\u0434\u0438\u043D
      \u0438\u0437 \u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043E\u0432 \u043C\u0430\u0448\u0438\u043D\u043D\u043E\u0433\u043E
      \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0430)"
    m_Metadata:
      m_Items: []
  - m_Id: 88938520903835652
    m_Localized: "\u0420\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0438\u0442\u0435
      \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044E!"
    m_Metadata:
      m_Items: []
  - m_Id: 88938520903835654
    m_Localized: "\u0421\u0432\u044F\u0436\u0438\u0442\u0435\u0441\u044C \u0441\u043E
      \u043C\u043D\u043E\u0439"
    m_Metadata:
      m_Items: []
  - m_Id: 88938520903835655
    m_Localized: "\u0415\u0441\u043B\u0438 \u0443 \u0432\u0430\u0441 \u0435\u0441\u0442\u044C
      \u0447\u0442\u043E-\u0442\u043E \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E\u0435
      \u043D\u0430 \u0443\u043C\u0435, \u0434\u0430\u0439\u0442\u0435 \u0437\u043D\u0430\u0442\u044C!"
    m_Metadata:
      m_Items: []
  - m_Id: 88938520903835656
    m_Localized: "gamesbytraust@gmail.com\n(\u043D\u0430\u0436\u043C\u0438\u0442\u0435,
      \u0447\u0442\u043E\u0431\u044B \u0441\u043A\u043E\u043F\u0438\u0440\u043E\u0432\u0430\u0442\u044C)"
    m_Metadata:
      m_Items: []
  - m_Id: 88939791366905856
    m_Localized: "\u0415\u0441\u043B\u0438 \u0432\u0430\u043C \u0445\u043E\u0447\u0435\u0442\u0441\u044F
      \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0430\u0442\u044C \u0438\u0433\u0440\u0443
      \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043F\u043E\u043A\u0443\u043F\u043A\u043E\u0439
      \u0432 Steam:"
    m_Metadata:
      m_Items: []
  - m_Id: 88940333384228864
    m_Localized: "\u0441\u043A\u043E\u043F\u0438\u0440\u043E\u0432\u0430\u043D\u043E"
    m_Metadata:
      m_Items: []
  - m_Id: 88943378960637952
    m_Localized: "\u0420\u0430\u0441\u0441\u043A\u0430\u0436\u0438\u0442\u0435 \u043E
      Red the Cook \u0434\u0440\u0443\u0437\u044C\u044F\u043C \u0438 \u043D\u0435
      \u0437\u0430\u0431\u0443\u0434\u044C\u0442\u0435 \u0434\u043E\u0431\u0430\u0432\u0438\u0442\u044C
      \u0438\u0433\u0440\u0443 \u0432 \u0441\u043F\u0438\u0441\u043E\u043A \u0436\u0435\u043B\u0430\u0435\u043C\u043E\u0433\u043E,
      \u044D\u0442\u043E \u043E\u0447\u0435\u043D\u044C \u043F\u043E\u043C\u043E\u0436\u0435\u0442
      \u043F\u0440\u043E\u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044E (\u0430
      \u0435\u0449\u0435 \u043C\u043D\u0435 \u0431\u0443\u0434\u0435\u0442 \u043F\u0440\u0438\u044F\u0442\u043D\u043E)"
    m_Metadata:
      m_Items: []
