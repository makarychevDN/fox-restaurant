%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Dialogues_en
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: 76c0caf3be1b6134fac28638aa766eea, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 96960955703296
    m_Localized: '*sigh*<pause:1> Another day, another dollar.'
    m_Metadata:
      m_Items: []
  - m_Id: 102732733243392
    m_Localized: Damn,<pause:0.5> this kiddo seems tough,<pause:0.5> he needs at
      least two icecreams.
    m_Metadata:
      m_Items: []
  - m_Id: 102851926974464
    m_Localized: Big boy, huh?<pause:0.75> The bigger they are, the harder they fall.
    m_Metadata:
      m_Items: []
  - m_Id: 102931308371968
    m_Localized: Stupid old junk.
    m_Metadata:
      m_Items: []
  - m_Id: 103157167448064
    m_Localized: Have to clean up the mess.
    m_Metadata:
      m_Items: []
  - m_Id: 103200687546368
    m_Localized: Where is the garbage can?
    m_Metadata:
      m_Items: []
  - m_Id: 103255913947136
    m_Localized: Oh,<pause:0.5> there you are.
    m_Metadata:
      m_Items: []
  - m_Id: 103266819137536
    m_Localized: Shoo,<pause:0.5> small stinkers.
    m_Metadata:
      m_Items: []
  - m_Id: 103795813146624
    m_Localized: Oh,<pause:0.5> wow.<pause:0.5> The first complex order for today.
    m_Metadata:
      m_Items: []
  - m_Id: 103882635239424
    m_Localized: Still too easy though.
    m_Metadata:
      m_Items: []
  - m_Id: 103985789952000
    m_Localized: Need to mix the ingredients.
    m_Metadata:
      m_Items: []
  - m_Id: 104019986112512
    m_Localized: '*sigh*<pause:1> I wonder what it''s like to cook real dishes?'
    m_Metadata:
      m_Items: []
  - m_Id: 104142648532992
    m_Localized: Oh,<pause:0.5> the real game begins.
    m_Metadata:
      m_Items: []
  - m_Id: 104186449649664
    m_Localized: It's easy.<pause:0.5> This thing spawns items,<pause:0.5> I use
      them.
    m_Metadata:
      m_Items: []
  - m_Id: 104222092845056
    m_Localized: The main thing is to keep it from clogging up.
    m_Metadata:
      m_Items: []
  - m_Id: 104300811542528
    m_Localized: '*sigh*<pause:1> Everyday in the same time.'
    m_Metadata:
      m_Items: []
  - m_Id: 104452712456192
    m_Localized: 'Oh,<pause: 0.5> it''s you again, Red <pause:0.5>NOT<pause:0.5>
      a Cook.'
    m_Metadata:
      m_Items: []
  - m_Id: 104546270601216
    m_Localized: 'Yarrr,<pause: 0.5> welcome aboard, young sailor.'
    m_Metadata:
      m_Items: []
  - m_Id: 104596988125184
    m_Localized: I don't need your greetings, Red <pause:0.5>NOT<pause:0.5> a Cook.
    m_Metadata:
      m_Items: []
  - m_Id: 104702047051776
    m_Localized: I need you to work faster, not louder.
    m_Metadata:
      m_Items: []
  - m_Id: 104734192197632
    m_Localized: Do you know that this is a restaurant for kids?
    m_Metadata:
      m_Items: []
  - m_Id: 104799568814080
    m_Localized: Pfft.<pause:0.5> This place is full of pirates.
    m_Metadata:
      m_Items: []
  - m_Id: 104851519463424
    m_Localized: Pirates are too scary for them,<pause:0.5> so <pause:0.5>YEAH,<pause:0.5>
      it's clearly for adults.
    m_Metadata:
      m_Items: []
  - m_Id: 104919387496448
    m_Localized: At least you are not too old for this.
    m_Metadata:
      m_Items: []
  - m_Id: 105019983683584
    m_Localized: I'm at the perfect age for this place, so, <pause:0.5>YEAH.
    m_Metadata:
      m_Items: []
  - m_Id: 105266793308160
    m_Localized: And I need some calories to be in the perfect shape.<pause:0.5>
      So, hurry up, Red <pause:0.5>NOT<pause:0.5> a Cook.
    m_Metadata:
      m_Items: []
  - m_Id: 105471504703488
    m_Localized: 'Pfft.<pause: 0.5> If you''ve done it doesn''t meen you''ve done
      it well,<pause: 0.5> Red <pause:0.5>NOT<pause:0.5> a cook.'
    m_Metadata:
      m_Items: []
  - m_Id: 105543625760768
    m_Localized: 'Yarrr,<pause: 0.5> we hope to see you again soon, young sailor.'
    m_Metadata:
      m_Items: []
  - m_Id: 105608289345536
    m_Localized: 'Oh, <pause:0.5>YEAH, <pause:0.5>do<pause: 0.5> NOT<pause: 0.5>
      hesitate.<pause:1> You will see me soon.'
    m_Metadata:
      m_Items: []
  - m_Id: 105693555351552
    m_Localized: And I won't be so easy on you next time.
    m_Metadata:
      m_Items: []
  - m_Id: 105789357449216
    m_Localized: See you later, Red <pause:0.5>NOT<pause:0.5> a cook.
    m_Metadata:
      m_Items: []
  - m_Id: 107592824283136
    m_Localized: <volume:0>.<pause:0.5>.<pause:0.5>.<pause:0.5><volume:1> Finally.
    m_Metadata:
      m_Items: []
  - m_Id: 107662542004224
    m_Localized: Whoa,<pause:0.5> break time already.
    m_Metadata:
      m_Items: []
  - m_Id: 131328193486848
    m_Localized: Damn...<pause:1> Ok, let's try again.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674043346944
    m_Localized: Finally, a moment of peace.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124160
    m_Localized: Yarr! <pause:0.75> Well then, swabbie, did you think your first
      day would be smooth sailing?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124161
    m_Localized: I've been working here for over a year.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124162
    m_Localized: Yarr! <pause:0.75> I couldn't make head nor tail of that!<pause:0.75>
      You sound like a landlubber!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124163
    m_Localized: I don't want to talk like that when I'm not at the register.<pause:0.75>
      It's<pause:0.5> ridiculous.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124164
    m_Localized: We're not pirates in real life.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124165
    m_Localized: <volume:0>...
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124166
    m_Localized: <volume:0>.<pause:0.5>.<pause:0.5>.<pause:0.5><volume:1> *sigh*
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124167
    m_Localized: Yarr!<pause:0.75> Captain,<pause:0.75> I've been on this voyage
      for over a year!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124168
    m_Localized: <volume:1>Yarr!<pause:0.75> That's more like it!<pause:0.75> Keep
      that up and the treasure won't be long in coming!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124169
    m_Localized: Speaking of treasure.<pause:0.75> I actually wanted to discuss my
      promotion and ...
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124170
    m_Localized: And cheer up, sailor!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124171
    m_Localized: I don't know what happened to you on shore.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124172
    m_Localized: But if you keep walking around looking that grumpy, you'll scare
      off all my customers!<pause:0.75> Yarr!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124173
    m_Localized: It's just...
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124174
    m_Localized: ...my face.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124175
    m_Localized: <volume:0>.<pause:0.5>.<pause:0.5>.<pause:0.5><volume:1> Deaf mutt.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124176
    m_Localized: Already?!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124177
    m_Localized: I swear, the breaks get shorter every day!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124178
    m_Localized: I'll show him.<pause:1> I'll show all of them.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124179
    m_Localized: I'll open my own restaurant,<pause:0.5> hire every last one of them,<pause:0.5>
      and then give them the shortest breaks imaginable.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124180
    m_Localized: And I'll give myself an outrageously long break!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124181
    m_Localized: But I won't even want to use it, that's how amazing my place will
      be!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124182
    m_Localized: <volume:0>.<pause:0.5>.<pause:0.5>.<pause:0.5><volume:1> On second
      thought, maybe I should make it slightly less amazing.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124183
    m_Localized: Otherwise they won't want to take their breaks at all.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124184
    m_Localized: Oh,<pause:0.75> it's her again.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124185
    m_Localized: She needs a special approach.<pause:0.75> She looks at what others
      are eating and orders the same thing.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124186
    m_Localized: The poor thing tends to doubt.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124187
    m_Localized: There we go.<pause:0.75> Ice cream for everyone!<pause:0.75> And
      I didn't even break a sweat!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124188
    m_Localized: <volume:0>...
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124189
    m_Localized: Yarr,<pause:0.75> is everything alright, young sailor?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124190
    m_Localized: <volume:0>.<pause:0.5>.<pause:0.5>.<pause:0.5><volume:1> I just
      wanted to say thank you!<pause:0.5> You were very patient.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124191
    m_Localized: Usually adults swear when I doubt a lot.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124192
    m_Localized: Yarr,<pause:0.5> don't you worry, young sailor,<pause:0.5> and come
      back anytime!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124193
    m_Localized: You're awesome!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124194
    m_Localized: <volume:0>.<pause:0.5>.<pause:0.5>.<pause:0.5><volume:1> Hm,<pause:0.75>
      maybe this day<pause:0.75> isn't so bad after all.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124195
    m_Localized: Hey,<pause:0.5> Red,<pause:0.5> come on,<pause:0.5> we need to talk.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124196
    m_Localized: Hi, Red.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124197
    m_Localized: Hi, Stan.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124198
    m_Localized: My eyes are lower.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124199
    m_Localized: Oh.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124200
    m_Localized: Yeah,<pause:0.75> that's better.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124201
    m_Localized: So what did you want?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124202
    m_Localized: <volume:0>.<pause:0.5>.<pause:0.5>.<pause:0.5><volume:1> I have
      to go out into the dining area in a minute.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124203
    m_Localized: What?!<pause:0.75> No!<pause:0.75> I object!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124204
    m_Localized: The Captain said he'd have me fed to the fish<pause:0.5> if I don't
      do it.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124205
    m_Localized: I'm not entirely sure what that means in plain English,<pause:0.5>
      but I'm certain it's nothing good.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124206
    m_Localized: But the kids go crazy for Peg-Leg Joe!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124207
    m_Localized: They'll tear this place apart if they see you in the costume!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124208
    m_Localized: I won't be able to handle that many customers!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124209
    m_Localized: We need at least three people on the register to keep up!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124210
    m_Localized: And I'm on my own today!<pause:0.75> Remember what happened last
      time!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124211
    m_Localized: I know.<pause:0.75> That's why I came to talk it through.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124212
    m_Localized: So,<pause:0.5> do you actually have a plan?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124213
    m_Localized: Yes,<pause:0.5> movie night.<pause:0.5> You draw the curtains,<pause:0.5>
      turn on the projector,<pause:0.5> and I'll make sure everyone keeps it down.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124214
    m_Localized: Movie night, huh.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124215
    m_Localized: That means I'll have to take on the evening menu with the cocktails.<pause:0.75>
      That won't be easy.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124216
    m_Localized: Still easier than if all the kids from all over the neighborhood
      come running here at once.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124217
    m_Localized: <volume:0>.<pause:0.5>.<pause:0.5>.<pause:0.5><volume:1> Yeah,<pause:0.5>
      you're right.<pause:0.75> You're a genius, Stan.<pause:0.75> Let's do it.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124218
    m_Localized: Deal.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124219
    m_Localized: Alright,<pause:0.75> let's try this.<pause:1> 3,<pause:1> 2<pause:1>
      1.<pause:1> Go!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124220
    m_Localized: Oh my gosh,<pause:0.4> it's Peg-Leg Joe!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124221
    m_Localized: Yay,<pause:0.4> Peg-Leg Joe!<pause:0.4> Give me a ride!!!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124222
    m_Localized: Me too!!!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124223
    m_Localized: Yarr!<pause:0.75> Peg-Leg Joe isn't feeling his best today,<pause:0.4>
      so we're going to keep it quiet.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318464
    m_Localized: Aww,<pause:0.75> that's not fair!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318465
    m_Localized: I thought we were going to have fun.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318466
    m_Localized: Don't worry, young sailor,<pause:0.75> we don't have to be loud
      to have fun!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318467
    m_Localized: For example,<pause:0.75> we could watch a cartoon!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318468
    m_Localized: Cartoons are good.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318469
    m_Localized: Only if it's interesting!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318470
    m_Localized: I hope<pause:0.5> there's a starfish in it...
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318471
    m_Localized: Yarr,<pause:0.75> of course it's interesting!<pause:0.75> But we'll
      be watching it quietly.<pause:0.5> Deal, young sailors?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318472
    m_Localized: Deal!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318473
    m_Localized: <volume:0>.<pause:0.5>.<pause:0.5>.<pause:0.5><volume:1> It worked!<pause:0.75>
      No crowd showed up!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318474
    m_Localized: Told you!<pause:0.75> A foolproof plan!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318475
    m_Localized: Now there's only one thing left.<pause:0.75> Back to work!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318476
    m_Localized: Phew,<pause:0.5> young sailors,<pause:0.5> who else wants some ice
      cream?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318477
    m_Localized: <volume:0>...
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318478
    m_Localized: Looks like<pause:0.5> you already handled everything.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318479
    m_Localized: Could you please keep it down?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318480
    m_Localized: <volume:1>We're trying to watch.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318481
    m_Localized: Oh,<pause:0.5> sorry.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318482
    m_Localized: Oh, come on!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318483
    m_Localized: Hey,<pause:0.5> we weren't done watching!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318484
    m_Localized: <volume:0.5>Yarr!<pause:0.5> What do you think you're doing here,
      swabbies?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318485
    m_Localized: I told you to send out Peg-Leg Joe, not for you to hang around here!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318486
    m_Localized: <emote:shake><volume:1>Hey,<pause:0.5><emote:shake> young sailors,<pause:0.5><emote:shake>
      Peg-Leg Joe has been hiding here this whole time!<pause:0.5><emote:shake> Get
      in here,<pause:0.5><emote:shake> show him how much you love him!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318487
    m_Localized: <volume:0.5>Forward, swabbies,<pause:0.75> bring me all the treasures
      in the world!<pause:0.75> Hahahahaha!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318488
    m_Localized: It's Peg-Leg Joe!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318489
    m_Localized: Run to him!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318490
    m_Localized: Oh no.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318491
    m_Localized: '*sigh* <pause:1> Home.'
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318492
    m_Localized: Huh?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318493
    m_Localized: What the...
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318494
    m_Localized: Silver
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318495
    m_Localized: If you go out without a hat, I'm telling Mom
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318496
    m_Localized: DON'T
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318497
    m_Localized: new message
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318498
    m_Localized: Come to the kitchen
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318499
    m_Localized: Hey there!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318500
    m_Localized: You do realize you can't just break into my place like that?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318501
    m_Localized: It was unlocked.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318502
    m_Localized: And why are you sitting here in the dark?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318503
    m_Localized: I'm feeling playful.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318504
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318505
    m_Localized: Oh,<pause:0.5> don't act like you're not happy to see me.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318506
    m_Localized: I am.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318507
    m_Localized: So.<pause:0.75> Why are you here?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318508
    m_Localized: Can't I just drop by to check on my little brother?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318509
    m_Localized: You can,<pause:0.75> but you don't.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318510
    m_Localized: Wow. Is that really how little you think of me?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318511
    m_Localized: Alright,<pause:0.75> you got me.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318512
    m_Localized: I'm not here for no reason.<pause:0.75> I have a proposition for
      you.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318513
    m_Localized: NO!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318514
    m_Localized: You didn't even hear me out.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318515
    m_Localized: NO!<pause:0.75> I'm out of the game!<pause:0.75> I'm just a regular
      cook now, remember?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318516
    m_Localized: You're serving ice cream at a children's restaurant.<pause:0.75>
      You're not a cook.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318517
    m_Localized: I practice a lot at home!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318518
    m_Localized: And I know you're good.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318519
    m_Localized: But being a cook isn't a hobby,<pause:0.75> it's a profession.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318520
    m_Localized: Did you come here just to insult me?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512768
    m_Localized: I actually came to help you with that.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512769
    m_Localized: First of all, I don't like the sound of that.<pause:0.75> And second,
      you don't understand anything about cooking.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512770
    m_Localized: Maybe not.<pause:0.75> But I do understand that you're going about
      your goal the wrong way.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512771
    m_Localized: Red,<pause:0.75> you're not keeping up.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512772
    m_Localized: Worse,<pause:0.75> what you're going through isn't bringing you
      closer to your goal.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512773
    m_Localized: It's pushing you further away.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512774
    m_Localized: No, it's not!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512775
    m_Localized: Take a look at this!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512776
    m_Localized: Behold!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512777
    m_Localized: my goal
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512778
    m_Localized: See?<pause:0.5> I'm already halfway there!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512779
    m_Localized: I don't drag myself to that damn job day after day for nothing!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512780
    m_Localized: Every month, there's more and more money in the jar!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512781
    m_Localized: And when I fill this up, I'll open a restaurant where I serve the
      best dishes around!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512782
    m_Localized: And the staff will get outrageously long breaks!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512783
    m_Localized: But working there will be so amazing no one will even want to take
      them!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512784
    m_Localized: And no one will ever say Red isn't a real cook!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512785
    m_Localized: No one!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512786
    m_Localized: Oh, you grumpy little cupcake
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512787
    m_Localized: I'm not arguing that you work hard.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512788
    m_Localized: It's opposite.<pause:0.5> You've buried yourself in cooking so deep
      you forgot to keep your eyes open.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512789
    m_Localized: Red,<pause:0.5> how long ago did you set this goal?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512790
    m_Localized: A year and a half ago.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512791
    m_Localized: Have you seen how much prices have gone up since then?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512792
    m_Localized: Well, prices always go up a little.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512793
    m_Localized: Just look at how much that equipment you liked back then costs now.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512794
    m_Localized: Oh come on,<pause:0.5> it can't be that bad.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512795
    m_Localized: I'm sure you could move mountains with that stubbornness of yours.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512796
    m_Localized: But if you keep going like this, you'll drift even further from
      your goal.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512797
    m_Localized: Things are getting more expensive faster than you're earning.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512798
    m_Localized: So what am I supposed to do?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512799
    m_Localized: Take action.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512800
    m_Localized: This still isn't enough to cover your whole vision.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512801
    m_Localized: But it's decent starting capital for something more modest.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512802
    m_Localized: For example,<pause:0.75> a small restaurant in a smaller town.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512803
    m_Localized: I've already scoped out a promising spot.<pause:0.75> Our money
      would cover the down payment.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512804
    m_Localized: Down payment?<pause:0.75> A loan sounds pretty<pause:0.5> risky.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512805
    m_Localized: Of course,<pause:0.75> but you know how it works.<pause:0.75> No
      risk, no reward.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512806
    m_Localized: Actually, you know what?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512807
    m_Localized: You're right!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512808
    m_Localized: Heck the ice cream restaurant!<pause:0.75> Heck all of them!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512809
    m_Localized: If I have to talk like a pirate for one more day, I'll lose my mind!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512810
    m_Localized: Now that's the spirit!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512811
    m_Localized: <volume:0>.<pause:0.5>.<pause:0.5>.<pause:0.5><volume:1> And what's
      in it for you?<pause:0.75> Why help me?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512812
    m_Localized: Well,<pause:0.75> first of all,<pause:0.75> because I worry about
      my little brother.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512813
    m_Localized: Who would absolutely get himself into trouble without me.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512814
    m_Localized: And second, I want a share.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674072707072
    m_Localized: I don't believe you!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674072707073
    m_Localized: You can practically make money out of thin air!
    m_Metadata:
      m_Items: []
  - m_Id: 39858674072707074
    m_Localized: Why would you want a stake in some random restaurant?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674072707075
    m_Localized: Oh, did you really think I'd never grow up?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674072707076
    m_Localized: "That I wouldn\u2019t want to settle down?<pause:0.75> Have a legitimate
      source of income?"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674072707077
    m_Localized: You're hurting my feelings.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674072707078
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 39858674072707079
    m_Localized: What?<pause:0.75> Do you really think I'm trying to trick you?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674072707080
    m_Localized: How many times have I ever tried to hurt you?<pause:0.75> Rob you?<pause:0.75>
      Set you up?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674072707081
    m_Localized: Not once.
    m_Metadata:
      m_Items: []
  - m_Id: 39858674072707082
    m_Localized: Then what are you waiting for?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674072707083
    m_Localized: Partners?
    m_Metadata:
      m_Items: []
  - m_Id: 39858674072707084
    m_Localized: <volume:0>.<pause:0.5>.<pause:0.5>.<pause:0.5><volume:1> Alright,<pause:0.75>
      partners!
    m_Metadata:
      m_Items: []
  - m_Id: 39890501168685056
    m_Localized: And their incredible adventure has begun!
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
