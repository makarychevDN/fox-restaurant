    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124179
    m_Localized: "\u041E\u0442\u043A\u0440\u043E\u044E \u0440\u0435\u0441\u0442\u043E\u0440\u0430\u043D,<pause:0.5>
      \u0432\u043E\u0437\u044C\u043C\u0443 \u0432\u0441\u0435\u0445 \u043D\u0430
      \u0440\u0430\u0431\u043E\u0442\u0443,<pause:0.5> \u0430 \u043F\u043E\u0442\u043E\u043C
      \u0441\u0434\u0435\u043B\u0430\u044E \u0438\u043C \u043A\u043E\u0440\u043E\u0442\u043A\u0438\u0435
      \u043F\u0435\u0440\u0435\u0440\u044B\u0432\u044B."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124180
    m_Localized: "\u0410 \u0441\u0435\u0431\u0435 \u0441\u0434\u0435\u043B\u0430\u044E
      \u0432\u043E\u0437\u043C\u0443\u0442\u0438\u0442\u0435\u043B\u044C\u043D\u043E
      \u0434\u043B\u0438\u043D\u043D\u044B\u0439 \u043F\u0435\u0440\u0435\u0440\u044B\u0432!"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124181
