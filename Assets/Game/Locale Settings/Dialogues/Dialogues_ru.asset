    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318486
    m_Localized: "<emote:shake><volume:1>\u042D\u0439,<pause:0.5><emote:shake> \u044E\u043D\u0433\u0438,<pause:0.5><emote:shake>
