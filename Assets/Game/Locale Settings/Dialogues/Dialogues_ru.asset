  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Dialogues_ru
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: ru
  m_SharedData: {fileID: 11400000, guid: 76c0caf3be1b6134fac28638aa766eea, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 96960955703296
    m_Localized: "*\u0432\u0437\u0434\u043E\u0445*<pause:1> \u041D\u043E\u0432\u044B\u0439
      \u0434\u0435\u043D\u044C - \u043D\u043E\u0432\u0430\u044F \u043A\u043E\u043F\u0435\u0439\u043A\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 102732733243392
    m_Localized: "\u0411\u043B\u0438\u043D,<pause:0.5> \u044D\u0442\u043E\u0442 \u043C\u0435\u043B\u043A\u0438\u0439
      \u0432\u044B\u0433\u043B\u044F\u0434\u0438\u0442 \u043A\u0440\u0435\u043F\u043A\u0438\u043C,<pause:0.5>
      \u0435\u043C\u0443 \u043F\u043E\u043D\u0430\u0434\u043E\u0431\u0438\u0442\u0441\u044F
      \u0445\u043E\u0442\u044F \u0431\u044B \u0434\u0432\u0435 \u043C\u043E\u0440\u043E\u0436\u0435\u043D\u043A\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 102851926974464
    m_Localized: "\u0411\u043E\u043B\u044C\u0448\u043E\u0439 \u043C\u0430\u043B\u044C\u0447\u0438\u043A,
      \u0434\u0430?<pause:0.75> \u0427\u0435\u043C \u0431\u043E\u043B\u044C\u0448\u0435
      \u0448\u043A\u0430\u0444, \u0442\u0435\u043C \u0433\u0440\u043E\u043C\u0447\u0435
      \u043F\u0430\u0434\u0430\u0435\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 102931308371968
    m_Localized: "\u0421\u0442\u0430\u0440\u0430\u044F \u0440\u0443\u0445\u043B\u044F\u0434\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 103157167448064
    m_Localized: "\u041D\u0443\u0436\u043D\u043E \u0432\u044B\u0447\u0438\u0441\u0442\u0438\u0442\u044C
      \u0431\u0435\u0441\u043F\u043E\u0440\u044F\u0434\u043E\u043A."
    m_Metadata:
      m_Items: []
  - m_Id: 103200687546368
    m_Localized: "\u0413\u0434\u0435 \u0436\u0435 \u043C\u0443\u0441\u043E\u0440\u043A\u0430?"
    m_Metadata:
      m_Items: []
  - m_Id: 103255913947136
    m_Localized: "\u041E,<pause:0.5> \u0432\u043E\u0442 \u0442\u044B \u0433\u0434\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 103266819137536
    m_Localized: "\u041A\u044B\u0448,<pause:0.5> \u0432\u043E\u043D\u044E\u0447\u043A\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 103795813146624
    m_Localized: "O\u0433\u043E.<pause:0.5> \u041F\u0435\u0440\u0432\u043E\u0435
      \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u043E\u0435 \u0431\u043B\u044E\u0434\u043E
      \u0437\u0430 \u0441\u0435\u0433\u043E\u0434\u043D\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 103882635239424
    m_Localized: "\u041D\u043E \u0432\u0441\u0435 \u0440\u0430\u0432\u043D\u043E
      \u044D\u0442\u043E \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u043F\u0440\u043E\u0441\u0442\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 103985789952000
    m_Localized: "\u041D\u0443\u0436\u043D\u043E \u0441\u043C\u0435\u0448\u0430\u0442\u044C
      \u0438\u043D\u0433\u0440\u0435\u0434\u0438\u0435\u043D\u0442\u044B."
    m_Metadata:
      m_Items: []
  - m_Id: 104019986112512
    m_Localized: "*\u0432\u0437\u0434\u043E\u0445*<pause:1> \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E,
      \u043A\u0430\u043A\u043E\u0432\u043E \u044D\u0442\u043E \u0433\u043E\u0442\u043E\u0432\u0438\u0442\u044C
      \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u0435 \u0431\u043B\u044E\u0434\u0430?"
    m_Metadata:
      m_Items: []
  - m_Id: 104142648532992
    m_Localized: "\u041E, <pause:0.5> \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0430\u044F
      \u0438\u0433\u0440\u0430 \u043D\u0430\u0447\u0438\u043D\u0430\u0435\u0442\u0441\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 104186449649664
    m_Localized: "\u042D\u0442\u043E \u043B\u0435\u0433\u043A\u043E.<pause:0.5> \u042D\u0442\u0430
      \u0448\u0442\u0443\u043A\u0430 \u043F\u043E\u0434\u043A\u0438\u0434\u044B\u0432\u0430\u0435\u0442
      \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u044B,<pause:0.5> \u044F \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E
      \u0438\u0445."
    m_Metadata:
      m_Items: []
  - m_Id: 104222092845056
    m_Localized: "\u0413\u043B\u0430\u0432\u043D\u043E\u0435 - \u043D\u0435 \u0434\u0430\u0432\u0430\u0442\u044C
      \u0435\u0439 \u0437\u0430\u0441\u043E\u0440\u0438\u0442\u044C\u0441\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 104300811542528
    m_Localized: "*\u0432\u0437\u0434\u043E\u0445*<pause:1> \u041A\u0430\u0436\u0434\u044B\u0439
      \u0434\u0435\u043D\u044C \u0432 \u043E\u0434\u043D\u043E \u0438 \u0442\u043E\u0436\u0435
      \u0432\u0440\u0435\u043C\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 104452712456192
    m_Localized: "O,<pause: 0.5> \u042D\u0442\u043E \u0441\u043D\u043E\u0432\u0430
      \u0442\u044B, \u0420\u044B\u0436\u0438\u0439 <pause:0.5>\u041D\u0415<pause:0.5>
      \u043F\u043E\u0432\u0430\u0440."
    m_Metadata:
      m_Items: []
  - m_Id: 104546270601216
    m_Localized: "\u042F\u0440\u0440\u0440,<pause: 0.5> \u0434\u043E\u0431\u0440\u043E
      \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u0442\u044C \u043D\u0430 \u0431\u043E\u0440\u0442,
      \u044E\u043D\u0433\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 104596988125184
    m_Localized: "\u041C\u043D\u0435 \u043D\u0435 \u043D\u0443\u0436\u043D\u044B
      \u043F\u0440\u0438\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u044F, \u0420\u044B\u0436\u0438\u0439
      <pause:0.5>\u041D\u0415<pause:0.5> \u043F\u043E\u0432\u0430\u0440."
    m_Metadata:
      m_Items: []
  - m_Id: 104702047051776
    m_Localized: "\u041C\u043D\u0435 \u043D\u0443\u0436\u043D\u043E, \u0447\u0442\u043E\u0431\u044B
      \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0431\u044B\u0441\u0442\u0440\u0435\u0435,
      \u0430 \u043D\u0435 \u0433\u0440\u043E\u043C\u0447\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 104734192197632
    m_Localized: "\u0422\u044B \u0436\u0435 \u0437\u043D\u0430\u0435\u0448\u044C,
      \u0447\u0442\u043E \u044D\u0442\u043E \u0434\u0435\u0442\u0441\u043A\u043E\u0435
      \u0437\u0430\u0432\u0435\u0434\u0435\u043D\u0438\u0435?"
    m_Metadata:
      m_Items: []
  - m_Id: 104799568814080
    m_Localized: "\u041F\u0444\u0444\u0442.<pause:0.5> \u042D\u0442\u043E \u043C\u0435\u0441\u0442\u043E
      \u043F\u043E\u043B\u043D\u043E \u043F\u0438\u0440\u0430\u0442\u043E\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 104851519463424
    m_Localized: "\u041F\u0438\u0440\u0430\u0442\u044B \u0441\u043B\u0438\u0448\u043A\u043E\u043C
      \u0441\u0442\u0440\u0430\u0448\u043D\u044B \u0434\u043B\u044F \u043D\u0438\u0445,<pause:0.5>
      \u0442\u0430\u043A \u0447\u0442\u043E, <pause:0.5>\u0414\u0410,<pause:0.5>
      \u043E\u0447\u0435\u0432\u0438\u0434\u043D\u043E, \u0447\u0442\u043E \u043E\u043D\u043E
      \u0434\u043B\u044F \u0432\u0437\u0440\u043E\u0441\u043B\u044B\u0445."
    m_Metadata:
      m_Items: []
  - m_Id: 104919387496448
    m_Localized: "\u041D\u0443 \u0442\u044B \u0445\u043E\u0442\u044F \u0431\u044B
      \u043D\u0435 \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u0441\u0442\u0430\u0440
      \u0434\u043B\u044F \u0432\u0441\u0435\u0433\u043E \u044D\u0442\u043E\u0433\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 105019983683584
    m_Localized: "\u042F \u0432 \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u043E\u043C
      \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 \u0434\u043B\u044F \u044D\u0442\u043E\u0433\u043E
      \u043C\u0435\u0441\u0442\u0430, \u0442\u0430\u043A \u0447\u0442\u043E, <pause:0.5>\u0414\u0410."
    m_Metadata:
      m_Items: []
  - m_Id: 105266793308160
    m_Localized: "\u0418 \u043C\u043D\u0435 \u043D\u0443\u0436\u043D\u044B \u043A\u0430\u043B\u043E\u0440\u0438\u0438,
      \u0447\u0442\u043E\u0431\u044B \u0431\u044B\u0442\u044C \u0432 \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u043E\u0439
      \u0444\u043E\u0440\u043C\u0435.<pause:0.5> \u0422\u0430\u043A \u0447\u0442\u043E
      \u043F\u043E\u0442\u043E\u0440\u0430\u043F\u043B\u0438\u0432\u0430\u0439\u0441\u044F,
      \u0420\u044B\u0436\u0438\u0439 <pause:0.5>\u041D\u0415<pause:0.5> \u043F\u043E\u0432\u0430\u0440."
    m_Metadata:
      m_Items: []
  - m_Id: 105471504703488
    m_Localized: "\u041F\u0444\u0444\u0442.<pause: 0.5> \u0442\u043E \u0447\u0442\u043E
      \u0442\u044B \u044D\u0442\u043E \u0441\u0434\u0435\u043B\u0430\u043B \u043D\u0435
      \u0437\u043D\u0430\u0447\u0438\u0442, \u0447\u0442\u043E \u0442\u044B \u0441\u0434\u0435\u043B\u0430\u043B
      \u044D\u0442\u043E \u0445\u043E\u0440\u043E\u0448\u043E,<pause: 0.5> \u0420\u044B\u0436\u0438\u0439
      <pause:0.5>\u041D\u0415<pause:0.5> \u043F\u043E\u0432\u0430\u0440."
    m_Metadata:
      m_Items: []
  - m_Id: 105543625760768
    m_Localized: "\u042F\u0440\u0440\u0440,<pause: 0.5> \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u0439\u0441\u044F
      \u0435\u0449\u0435, \u044E\u043D\u0433\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 105608289345536
    m_Localized: "\u041E\u0445, <pause:0.5>\u0414\u0410, <pause:0.5>\u043D\u0435
      \u0441\u043E\u043C\u043D\u0435\u0432\u0430\u0439\u0441\u044F.<pause:1> \u042F
      \u0432\u0435\u0440\u043D\u0443\u0441\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 105693555351552
    m_Localized: "\u0418 \u044F \u043D\u0435 \u0431\u0443\u0434\u0443 \u0442\u0430\u043A
      \u043C\u044F\u0433\u043E\u043A \u0441 \u0442\u043E\u0431\u043E\u0439 \u0432
      \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0439 \u0440\u0430\u0437."
    m_Metadata:
      m_Items: []
  - m_Id: 105789357449216
    m_Localized: "\u0415\u0449\u0435 \u0443\u0432\u0438\u0434\u0438\u043C\u0441\u044F,
      \u0420\u044B\u0436\u0438\u0439 <pause:0.5>\u041D\u0415<pause:0.5> \u043F\u043E\u0432\u0430\u0440."
    m_Metadata:
      m_Items: []
  - m_Id: 107592824283136
    m_Localized: "<volume:0>.<pause:0.5>.<pause:0.5>.<pause:0.5><volume:1> \u041D\u0430\u043A\u043E\u043D\u0435\u0446-\u0442\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 107662542004224
    m_Localized: "\u0412\u043E\u0443,<pause:0.5> \u0443\u0436\u0435 \u043F\u0435\u0440\u0435\u0440\u044B\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 131328193486848
    m_Localized: "\u0411\u043B\u0438\u043D...<pause:1> \u041B\u0430\u0434\u043D\u043E,
      \u043F\u043E\u043F\u0440\u043E\u0431\u0443\u0435\u043C \u0435\u0449\u0435 \u0440\u0430\u0437\u043E\u043A."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674043346944
    m_Localized: "\u041D\u0430\u043A\u043E\u043D\u0435\u0446-\u0442\u043E \u043C\u0438\u043D\u0443\u0442\u0430
      \u043F\u043E\u043A\u043E\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124160
    m_Localized: "\u0419\u0430\u0440\u0440! <pause:0.75> \u041D\u0443 \u0447\u0442\u043E,
      \u0441\u0430\u043B\u0430\u0433\u0430, \u0434\u0443\u043C\u0430\u043B, \u0447\u0442\u043E
      \u043F\u0435\u0440\u0432\u044B\u0439 \u0434\u0435\u043D\u044C \u0431\u0443\u0434\u0435\u0442
      \u043F\u0440\u043E\u0441\u0442\u044B\u043C?"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124161
    m_Localized: "\u042F \u0442\u0443\u0442 \u0440\u0430\u0431\u043E\u0442\u0430\u044E
      \u0431\u043E\u043B\u044C\u0448\u0435 \u0433\u043E\u0434\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124162
    m_Localized: "\u0419\u0430\u0440\u0440! <pause:0.75> \u042F \u043D\u0438 \u043E\u0434\u043D\u043E\u0433\u043E
      \u0441\u043B\u043E\u0432\u0430 \u043D\u0435 \u043F\u043E\u043D\u044F\u043B!<pause:0.75>
      \u0422\u044B \u0433\u043E\u0432\u043E\u0440\u0438\u0448\u044C, \u043A\u0430\u043A
      \u0441\u0443\u0445\u043E\u043F\u0443\u0442\u043D\u0430\u044F \u043A\u0440\u044B\u0441\u0430!"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124163
    m_Localized: "\u042F \u043D\u0435 \u0445\u043E\u0447\u0443 \u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C
      \u0442\u0430\u043A, \u043F\u043E\u043A\u0430 \u044F \u043D\u0435 \u0437\u0430
      \u043A\u0430\u0441\u0441\u043E\u0439.<pause:0.75> \u042D\u0442\u043E<pause:0.5>
      \u0433\u043B\u0443\u043F\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124164
    m_Localized: "\u041C\u044B \u0436\u0435 \u043D\u0435 \u043F\u0438\u0440\u0430\u0442\u044B
      \u0432 \u043E\u0431\u044B\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124165
    m_Localized: <volume:0>...
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124166
    m_Localized: "<volume:0>.<pause:0.5>.<pause:0.5>.<pause:0.5><volume:1> *\u0432\u0437\u0434\u043E\u0445*"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124167
    m_Localized: "\u0419\u0430\u0440\u0440!<pause:0.75> \u041A\u0430\u043F\u0438\u0442\u0430\u043D,<pause:0.75>
      \u044F \u0432 \u044D\u0442\u043E\u043C \u043F\u043B\u0430\u0432\u0430\u043D\u044C\u0435
      \u0443\u0436\u0435 \u0431\u043E\u043B\u044C\u0448\u0435 \u0433\u043E\u0434\u0430!"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124168
    m_Localized: "<volume:1>\u0419\u0430\u0440\u0440!<pause:0.75> \u0412\u043E\u0442
      \u0442\u0430\u043A \u0431\u044B \u0441\u0440\u0430\u0437\u0443!<pause:0.75>
      \u041F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0439 \u0432 \u0442\u043E\u043C
      \u0436\u0435 \u0434\u0443\u0445\u0435 \u0438 \u0441\u043E\u043A\u0440\u043E\u0432\u0438\u0449\u0435
      \u043D\u0435 \u0437\u0430\u0441\u0442\u0430\u0432\u0438\u0442 \u0441\u0435\u0431\u044F
      \u0434\u043E\u043B\u0433\u043E \u0436\u0434\u0430\u0442\u044C!"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124169
    m_Localized: "\u041A \u0441\u043B\u043E\u0432\u0443, \u043E \u0441\u043E\u043A\u0440\u043E\u0432\u0438\u0449\u0430\u0445.<pause:0.75>
