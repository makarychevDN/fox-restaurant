      \u043C\u0435\u043D\u044E \u0441 \u043A\u043E\u043A\u0442\u0435\u0439\u043B\u044F\u043C\u0438.<pause:0.75>
      \u0411\u0443\u0434\u0435\u0442 \u0442\u0440\u0443\u0434\u043D\u043E\u0432\u0430\u0442\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124216
    m_Localized: "\u0412\u0441\u0435 \u0435\u0449\u0435 \u043F\u0440\u043E\u0449\u0435,
      \u0447\u0435\u043C, \u0435\u0441\u043B\u0438 \u0441\u044E\u0434\u0430 \u0440\u0430\u0437\u043E\u043C
      \u0441\u0431\u0435\u0436\u0438\u0442\u0441\u044F \u0432\u0441\u044F \u0440\u0435\u0431\u044F\u0442\u043D\u044F
      \u0441\u043E \u0432\u0441\u0435\u0439 \u043E\u043A\u0440\u0443\u0433\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124217
    m_Localized: "<volume:0>.<pause:0.5>.<pause:0.5>.<pause:0.5><volume:1> \u0414\u0430,<pause:0.5>
      \u0442\u044B \u043F\u0440\u0430\u0432.<pause:0.75> \u0414\u0430 \u0442\u044B
      \u0433\u0435\u043D\u0438\u0439, \u0421\u0442\u044D\u043D.<pause:0.75> \u0422\u0430\u043A
      \u0438 \u0441\u0434\u0435\u043B\u0430\u0435\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124218
    m_Localized: "\u0414\u043E\u0433\u043E\u0432\u043E\u0440\u0438\u043B\u0438\u0441\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124219
    m_Localized: "\u0425\u043E\u0440\u043E\u0448\u043E,<pause:0.75> \u0434\u0430\u0432\u0430\u0439
      \u043F\u043E\u043F\u0440\u043E\u0431\u0443\u0435\u043C.<pause:1> 3,<pause:1>
      2,<pause:1> 1.<pause:1> \u041F\u043E\u0435\u0445\u0430\u043B\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674060124220
    m_Localized: "\u041E \u0431\u043E\u0436\u0435,<pause:0.4> \u044D\u0442\u043E
