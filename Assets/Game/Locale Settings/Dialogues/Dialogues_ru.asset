  - m_Id: 39858674064318509
    m_Localized: "\u0422\u044B \u043C\u043E\u0436\u0435\u0448\u044C,<pause:0.75> 
      \u043D\u043E \u0442\u044B \u0442\u0430\u043A \u043D\u0435 \u0434\u0435\u043B\u0430\u0435\u0448\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318510
    m_Localized: "\u041A\u0430\u043A \u043F\u043B\u043E\u0445\u043E \u0442\u044B
      \u043E\u0431\u043E \u043C\u043D\u0435 \u0434\u0443\u043C\u0430\u0435\u0448\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318511
    m_Localized: "\u041B\u0430\u0434\u043D\u043E,<pause:0.75> \u0442\u044B \u043C\u0435\u043D\u044F
      \u043F\u043E\u0434\u043B\u043E\u0432\u0438\u043B."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318512
    m_Localized: "\u042F \u0438 \u0432\u043F\u0440\u0430\u0432\u0434\u0443 \u043F\u0440\u0438\u0448\u0435\u043B
      \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0442\u0430\u043A.<pause:0.75>
      \u0423 \u043C\u0435\u043D\u044F \u0435\u0441\u0442\u044C \u0434\u043B\u044F
      \u0442\u0435\u0431\u044F \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318513
    m_Localized: "\u041D\u0415\u0422!"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318514
    m_Localized: "\u041D\u043E \u0442\u044B \u0434\u0430\u0436\u0435 \u043D\u0435
      \u0432\u044B\u0441\u043B\u0443\u0448\u0430\u043B."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318515
    m_Localized: "\u041D\u0415\u0422!<pause:0.75> \u042F \u0432\u044B\u0448\u0435\u043B
      \u0438\u0437 \u0438\u0433\u0440\u044B!<pause:0.75> \u042F \u0442\u0435\u043F\u0435\u0440\u044C
      \u043E\u0431\u044B\u0447\u043D\u044B\u0439 \u043F\u043E\u0432\u0430\u0440,
      \u0437\u0430\u0431\u044B\u043B?"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318516
    m_Localized: "\u0422\u044B \u043D\u0430\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0435\u0448\u044C
      \u043C\u043E\u0440\u043E\u0436\u0435\u043D\u043E\u0435 \u0432 \u0434\u0435\u0442\u0441\u043A\u043E\u043C
      \u0437\u0430\u0432\u0435\u0434\u0435\u043D\u0438\u0438.<pause:0.75> \u0422\u044B
      \u043D\u0435 \u043F\u043E\u0432\u0430\u0440."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318517
    m_Localized: "\u042F \u043C\u043D\u043E\u0433\u043E \u043F\u0440\u0430\u043A\u0442\u0438\u043A\u0443\u044E\u0441\u044C
      \u0434\u043E\u043C\u0430!"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318518
    m_Localized: "\u0418 \u044F \u0437\u043D\u0430\u044E, \u0447\u0442\u043E \u0443
      \u0442\u0435\u0431\u044F \u0445\u043E\u0440\u043E\u0448\u043E \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u0442\u0441\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318519
    m_Localized: "\u041D\u043E \u043F\u043E\u0432\u0430\u0440 - \u044D\u0442\u043E
      \u043D\u0435 \u0445\u043E\u0431\u0431\u0438,<pause:0.75> \u043F\u043E\u0432\u0430\u0440
      - \u044D\u0442\u043E \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318520
    m_Localized: "\u0422\u044B \u043F\u0440\u0438\u0448\u0435\u043B \u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C
      \u043E\u0431\u0438\u0434\u043D\u044B\u0435 \u0432\u0435\u0449\u0438 \u0438\u043B\u0438
      \u0447\u0442\u043E?"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512768
    m_Localized: "\u042F \u043D\u0430 \u0441\u0430\u043C\u043E\u043C \u0434\u0435\u043B\u0435
      \u043F\u0440\u0438\u0448\u0435\u043B \u0442\u0435\u0431\u0435 \u0441 \u044D\u0442\u0438\u043C
      \u043F\u043E\u043C\u043E\u0447\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512769
    m_Localized: "\u0412\u043E-\u043F\u0435\u0440\u0432\u044B\u0445 \u043C\u043D\u0435
      \u043D\u0435 \u043D\u0440\u0430\u0432\u0438\u0442\u0441\u044F.<pause:0.75>
      \u0410 \u0432\u043E-\u0432\u0442\u043E\u0440\u044B\u0445 \u0442\u044B \u043D\u0438\u0447\u0435\u0433\u043E
      \u043D\u0435 \u043F\u043E\u043D\u0438\u043C\u0430\u0435\u0448\u044C \u0432
      \u0433\u043E\u0442\u043E\u0432\u043A\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512770
    m_Localized: "\u0417\u0430\u0442\u043E \u044F \u043F\u043E\u043D\u0438\u043C\u0430\u044E,
      \u0447\u0442\u043E \u0442\u044B \u0438\u0434\u0435\u0448\u044C \u043A \u0441\u0432\u043E\u0435\u0439
      \u0446\u0435\u043B\u0438 \u043D\u0435\u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512771
    m_Localized: "\u0420\u044B\u0436\u0438\u0439,<pause:0.75> \u0442\u044B \u043D\u0435
      \u0432\u044B\u0432\u043E\u0437\u0438\u0448\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512772
    m_Localized: "\u0411\u043E\u043B\u0435\u0435 \u0442\u043E\u0433\u043E, \u0442\u043E,
      \u0447\u0435\u0440\u0435\u0437 \u0447\u0442\u043E \u0442\u044B \u043F\u0440\u043E\u0445\u043E\u0434\u0438\u0448\u044C
      \u0442\u0435\u0431\u044F \u043D\u0435 \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0430\u0435\u0442
      \u043A \u0446\u0435\u043B\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512773
    m_Localized: "\u0421\u043A\u043E\u0440\u0435\u0435 \u043E\u0442\u0434\u0430\u043B\u044F\u0435\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512774
    m_Localized: "\u0410 \u0432\u043E\u0442 \u0438 \u043D\u0435\u0442!"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512775
    m_Localized: "\u041F\u043E\u0441\u043C\u043E\u0442\u0440\u0438 \u043A\u0430 \u043D\u0430
      \u044D\u0442\u043E!"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512776
    m_Localized: "\u0423\u0437\u0440\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512777
    m_Localized: "\u043C\u043E\u044F \u0446\u0435\u043B\u044C"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512778
    m_Localized: "\u0412\u0438\u0434\u0438\u0448\u044C?<pause:0.5> \u042F \u0443\u0436\u0435
      \u043D\u0430 \u043F\u043E\u043B \u043F\u0443\u0442\u0438 \u043A \u0446\u0435\u043B\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512779
    m_Localized: "\u042F \u0434\u0435\u043D\u044C \u0437\u0430 \u0434\u043D\u0435\u043C
      \u0445\u043E\u0436\u0443 \u043D\u0430 \u044D\u0442\u0443 \u0447\u0435\u0440\u0442\u043E\u0432\u0443
      \u0440\u0430\u0431\u043E\u0442\u0443 \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
      \u0442\u0430\u043A!"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512780
    m_Localized: "\u0421 \u043A\u0430\u0436\u0434\u044B\u043C \u043C\u0435\u0441\u044F\u0446\u0435\u043C
      \u0432 \u0431\u0430\u043D\u043E\u0447\u043A\u0435 \u0432\u0441\u0435 \u0431\u043E\u043B\u044C\u0448\u0435
      \u0434\u0435\u043D\u0435\u0433!"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512781
    m_Localized: "\u0410 \u043A\u043E\u0433\u0434\u0430 \u044F \u0435\u0435 \u0437\u0430\u043F\u043E\u043B\u043D\u044E,
      \u044F \u043E\u0442\u043A\u0440\u043E\u044E \u0440\u0435\u0441\u0442\u043E\u0440\u0430\u043D,
      \u0433\u0434\u0435 \u0431\u0443\u0434\u0443 \u043F\u043E\u0434\u0430\u0432\u0430\u0442\u044C
      \u0441\u0430\u043C\u044B\u0435 \u0432\u043A\u0443\u0441\u043D\u044B\u0435 \u0431\u043B\u044E\u0434\u0430!"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512782
    m_Localized: "\u0418 \u0432 \u043D\u0435\u043C \u0431\u0443\u0434\u0443\u0442
      \u0432\u043E\u0437\u043C\u0443\u0442\u0438\u0442\u0435\u043B\u044C\u043D\u043E
      \u0434\u043E\u043B\u0433\u0438\u0435 \u043F\u0435\u0440\u0435\u0440\u044B\u0432\u044B
      \u0434\u043B\u044F \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A\u043E\u0432!"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512783
    m_Localized: "\u041D\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C \u0432
      \u043D\u0435\u043C \u0431\u0443\u0434\u0435\u0442 \u0442\u0430\u043A \u043A\u043B\u0430\u0441\u0441\u043D\u043E,
      \u0447\u0442\u043E \u043D\u0438\u043A\u0442\u043E \u043D\u0435 \u0437\u0430\u0445\u043E\u0447\u0435\u0442
      \u0438\u043C\u0438 \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C\u0441\u044F!"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512784
    m_Localized: "\u0418 \u0431\u043E\u043B\u044C\u0448\u0435 \u043D\u0438\u043A\u0442\u043E
      \u043D\u0435 \u0441\u043A\u0430\u0436\u0435\u0442, \u0447\u0442\u043E \u0420\u044B\u0436\u0438\u0439
      - \u043D\u0435 \u043F\u043E\u0432\u0430\u0440!"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512785
    m_Localized: "\u041D\u0438\u043A\u0442\u043E!"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512786
    m_Localized: "\u0414\u0430 \u0442\u044B \u043C\u043E\u044F \u0432\u043E\u0440\u0447\u043B\u0438\u0432\u0430\u044F
      \u0431\u0443\u043B\u043E\u0447\u043A\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512787
    m_Localized: "\u042F \u0438 \u043D\u0435 \u0441\u043F\u043E\u0440\u044E, \u0447\u0442\u043E
      \u0442\u044B \u0442\u0440\u0443\u0434\u0438\u0448\u044C\u0441\u044F \u043E\u0447\u0435\u043D\u044C
      \u0443\u0441\u0435\u0440\u0434\u043D\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512788
    m_Localized: "\u0421\u043A\u043E\u0440\u0435\u0435 \u043D\u0430\u043E\u0431\u043E\u0440\u043E\u0442,<pause:0.5>
      \u0442\u044B \u0442\u0430\u043A \u0437\u0430\u043A\u043E\u043F\u0430\u043B\u0441\u044F
      \u0432 \u0433\u043E\u0442\u043E\u0432\u043A\u0443, \u0447\u0442\u043E \u0437\u0430\u0431\u044B\u043B
      \u0434\u0435\u0440\u0436\u0430\u0442\u044C \u043D\u043E\u0441 \u043F\u043E
      \u0432\u0435\u0442\u0440\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512789
    m_Localized: "\u0420\u044B\u0436\u0438\u0439,<pause:0.5> \u043A\u0430\u043A \u0434\u0430\u0432\u043D\u043E
      \u0442\u044B \u043F\u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0441\u0435\u0431\u0435
      \u044D\u0442\u0443 \u0446\u0435\u043B\u044C?"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512790
    m_Localized: "\u041F\u043E\u043B\u0442\u043E\u0440\u0430 \u0433\u043E\u0434\u0430
      \u043D\u0430\u0437\u0430\u0434."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512791
    m_Localized: "\u0422\u044B \u0432\u0438\u0434\u0435\u043B, \u043A\u0430\u043A
      \u0446\u0435\u043D\u044B \u0437\u0430 \u044D\u0442\u043E \u0432\u0440\u0435\u043C\u044F
      \u043F\u043E\u0434\u0441\u043A\u043E\u0447\u0438\u043B\u0438?"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512792
    m_Localized: "\u041D\u0443, \u0446\u0435\u043D\u044B \u0432\u0441\u0435\u0433\u0434\u0430
      \u043F\u043E\u043D\u0435\u043C\u043D\u043E\u0433\u0443 \u0440\u0430\u0441\u0442\u0443\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512793
    m_Localized: "\u041F\u0440\u043E\u0441\u0442\u043E \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0438,
      \u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0441\u0442\u043E\u0438\u0442 \u0442\u043E
      \u043E\u0431\u043E\u0440\u0443\u0434\u043E\u0432\u0430\u043D\u0438\u0435, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
      \u0442\u0435\u0431\u0435 \u0442\u043E\u0433\u0434\u0430 \u043F\u0440\u0438\u0433\u043B\u044F\u043D\u0443\u043B\u043E\u0441\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512794
    m_Localized: "\u041E\u0439, \u043D\u0443, \u043D\u0435 \u043C\u043E\u0436\u0435\u0442
      \u0436\u0435 \u0431\u044B\u0442\u044C \u0432\u0441\u0435 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
      \u043F\u043B\u043E\u0445\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512795
    m_Localized: "\u042F \u0443\u0432\u0435\u0440\u0435\u043D, \u0447\u0442\u043E
      \u0442\u044B \u0441\u0432\u043E\u0438\u043C \u0443\u043F\u0440\u044F\u043C\u0441\u0442\u0432\u043E\u043C
      \u043C\u043E\u0436\u0435\u0448\u044C \u0433\u043E\u0440\u044B \u0441\u0432\u0435\u0440\u043D\u0443\u0442\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512796
    m_Localized: "\u041D\u043E, \u0435\u0441\u043B\u0438 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0448\u044C
      \u0432 \u0442\u043E\u043C \u0436\u0435 \u0434\u0443\u0445\u0435, \u0442\u043E
      \u043E\u0442\u0434\u0430\u043B\u0438\u0448\u044C\u0441\u044F \u043E\u0442 \u0446\u0435\u043B\u0438
      \u0435\u0449\u0435 \u0441\u0438\u043B\u044C\u043D\u0435\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512797
    m_Localized: "\u0412\u0435\u0449\u0438 \u0434\u043E\u0440\u043E\u0436\u0430\u044E\u0442
      \u0431\u044B\u0441\u0442\u0440\u0435\u0435, \u0447\u0435\u043C \u0442\u044B
      \u0437\u0430\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u0435\u0448\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512798
    m_Localized: "\u0418 \u0447\u0442\u043E \u043C\u043D\u0435 \u0442\u043E\u0433\u0434\u0430
      \u0434\u0435\u043B\u0430\u0442\u044C?"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512799
    m_Localized: "\u0414\u0435\u0439\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512800
    m_Localized: "\u0417\u0434\u0435\u0441\u044C \u0432\u0441\u0435 \u0435\u0449\u0435
      \u043D\u0435 \u0445\u0432\u0430\u0442\u0438\u0442 \u043D\u0430 \u0442\u043E,
      \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u043A\u0440\u044B\u0442\u044C \u0432\u0441\u044E
      \u0442\u0432\u043E\u044E \u0437\u0430\u0434\u0443\u043C\u043A\u0443 \u0432
      \u043F\u043E\u043B\u043D\u043E\u0439 \u043C\u0435\u0440\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512801
    m_Localized: "\u041D\u043E \u044D\u0442\u043E \u043D\u0435\u043F\u043B\u043E\u0445\u043E\u0439
      \u0441\u0442\u0430\u0440\u0442\u043E\u0432\u044B\u0439 \u043A\u0430\u043F\u0438\u0442\u0430\u043B,
      \u0447\u0442\u043E\u0431\u044B \u043D\u0430\u0447\u0430\u0442\u044C \u0441
      \u0447\u0435\u0433\u043E-\u0442\u043E \u0431\u043E\u043B\u0435\u0435 \u0441\u043A\u0440\u043E\u043C\u043D\u043E\u0433\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512802
    m_Localized: "\u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,<pause:0.75> \u0441
      \u0440\u0435\u0441\u0442\u043E\u0440\u0430\u043D\u0447\u0438\u043A\u0430 \u0432
      \u0433\u043E\u0440\u043E\u0434\u0435 \u043F\u043E\u043C\u0435\u043D\u044C\u0448\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512803
    m_Localized: "\u042F \u0443\u0436\u0435 \u043F\u0440\u0438\u0441\u043C\u043E\u0442\u0440\u0435\u043B
      \u043E\u0434\u043D\u043E \u043D\u0435\u043F\u043B\u043E\u0445\u043E\u0435 \u043C\u0435\u0441\u0442\u0435\u0447\u043A\u043E.<pause:0.75>
      \u041D\u0430\u0448\u0438\u0445 \u0434\u0435\u043D\u0435\u0433 \u0445\u0432\u0430\u0442\u0438\u0442
      \u043D\u0430 \u043F\u0435\u0440\u0432\u044B\u0439 \u0432\u0437\u043D\u043E\u0441."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512804
    m_Localized: "\u041F\u0435\u0440\u0432\u044B\u0439 \u0432\u0437\u043D\u043E\u0441?<pause:0.75>
      \u041A\u0440\u0435\u0434\u0438\u0442 \u0437\u0432\u0443\u0447\u0438\u0442 \u0434\u043E\u0432\u043E\u043B\u044C\u043D\u043E<pause:0.5>
      \u0440\u0438\u0441\u043A\u043E\u0432\u0430\u043D\u043D\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512805
    m_Localized: "\u041A\u043E\u043D\u0435\u0447\u043D\u043E,<pause:0.75> \u043D\u043E
      \u0442\u044B \u0436\u0435 \u0441\u0430\u043C \u0437\u043D\u0430\u0435\u0448\u044C,
      \u043A\u0430\u043A \u044D\u0442\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442.<pause:0.75>
      \u041A\u0442\u043E \u043D\u0435 \u0440\u0438\u0441\u043A\u0443\u0435\u0442,
      \u0442\u043E\u0442 \u043D\u0435 \u043F\u044C\u0435\u0442 \u0448\u0430\u043C\u043F\u0430\u043D\u0441\u043A\u043E\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512806
    m_Localized: "\u0410 \u0432\u043E\u043E\u0431\u0449\u0435 \u0437\u043D\u0430\u0435\u0448\u044C
      \u0447\u0442\u043E?"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512807
    m_Localized: "\u0410 \u0442\u044B \u043F\u0440\u0430\u0432!"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512808
    m_Localized: "\u041A \u0447\u0435\u0440\u0442\u0443 \u043A\u0430\u0444\u0435
      \u043C\u043E\u0440\u043E\u0436\u0435\u043D\u043E\u0435!<pause:0.75> \u041A
      \u0447\u0435\u0440\u0442\u0443 \u0438\u0445 \u0432\u0441\u0435\u0445!"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512809
    m_Localized: "\u0415\u0441\u043B\u0438 \u044F \u0435\u0449\u0435 \u0445\u043E\u0442\u044F
      \u0431\u044B \u0434\u0435\u043D\u044C \u0431\u0443\u0434\u0443 \u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C
      \u043A\u0430\u043A \u043F\u0438\u0440\u0430\u0442 - \u044F \u0441\u0432\u0438\u0445\u043D\u0443\u0441\u044C!"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512810
    m_Localized: "\u0412\u043E\u0442 \u044D\u0442\u043E \u043D\u0430\u0441\u0442\u0440\u043E\u0439!"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512811
    m_Localized: "<volume:0>.<pause:0.5>.<pause:0.5>.<pause:0.5><volume:1> \u0410
      \u0442\u0435\u0431\u0435 \u043E\u043D\u043E \u0437\u0430\u0447\u0435\u043C?<pause:0.75>
      \u0417\u0430\u0447\u0435\u043C \u043F\u043E\u043C\u043E\u0433\u0430\u0442\u044C
      \u043C\u043D\u0435?"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512812
    m_Localized: "\u041D\u0443,<pause:0.75> \u0432\u043E-\u043F\u0435\u0440\u0432\u044B\u0445,<pause:0.75>
      \u043F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E \u044F \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0430\u044E
      \u0437\u0430 \u043C\u043E\u0435\u0433\u043E \u043C\u043B\u0430\u0434\u0448\u0435\u0433\u043E
      \u0431\u0440\u0430\u0442\u0438\u0448\u043A\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512813
    m_Localized: "\u041A\u043E\u0442\u043E\u0440\u044B\u0439 \u0431\u0435\u0437 \u043C\u0435\u043D\u044F
      \u043E\u0431\u044F\u0437\u0430\u0442\u0435\u043B\u044C\u043D\u043E \u043D\u0430\u0434\u0435\u043B\u0430\u0435\u0442
      \u0433\u043B\u0443\u043F\u043E\u0441\u0442\u0435\u0439."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674068512814
    m_Localized: "\u0410 \u0432\u043E-\u0432\u0442\u043E\u0440\u044B\u0445 \u044F
      \u0445\u043E\u0447\u0443 \u0432 \u0434\u043E\u043B\u044E."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674072707072
    m_Localized: "\u042F \u0442\u0435\u0431\u0435 \u043D\u0435 \u0432\u0435\u0440\u044E!"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674072707073
    m_Localized: "\u0422\u044B \u0431\u0443\u043A\u0432\u0430\u043B\u044C\u043D\u043E
      \u043C\u043E\u0436\u0435\u0448\u044C \u0434\u0435\u043B\u0430\u0442\u044C \u0434\u0435\u043D\u044C\u0433\u0438
      \u0438\u0437 \u0432\u043E\u0437\u0434\u0443\u0445\u0430!"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674072707074
    m_Localized: "\u0417\u0430\u0447\u0435\u043C \u0442\u0435\u0431\u0435 \u0434\u043E\u043B\u044F
      \u043A\u0430\u043A\u043E\u0439-\u0442\u043E \u043A\u0430\u0444\u0435\u0448\u043A\u0438?"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674072707075
    m_Localized: "\u041E\u0439, \u043D\u0443 \u0442\u044B \u043F\u0440\u0430\u0432\u0434\u0430
      \u0434\u0443\u043C\u0430\u043B, \u0447\u0442\u043E \u044F \u043D\u0438\u043A\u043E\u0433\u0434\u0430
      \u043D\u0435 \u043F\u043E\u0432\u0437\u0440\u043E\u0441\u043B\u0435\u044E?"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674072707076
    m_Localized: "\u041D\u0435 \u0437\u0430\u0445\u043E\u0447\u0443 \u043E\u0441\u0442\u0435\u043F\u0435\u043D\u0438\u0442\u044C\u0441\u044F?<pause:0.75>
      \u041E\u0431\u0437\u0430\u0432\u0435\u0441\u0442\u0438\u0441\u044C \u043B\u0435\u0433\u0430\u043B\u044C\u043D\u044B\u043C
      \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u043E\u043C \u0434\u043E\u0445\u043E\u0434\u0430?"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674072707077
    m_Localized: "\u0422\u044B \u043C\u0435\u043D\u044F \u043E\u0431\u0438\u0436\u0430\u0435\u0448\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674072707078
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 39858674072707079
    m_Localized: "\u041D\u0443 \u0447\u0442\u043E \u0442\u0430\u043A\u043E\u0435?<pause:0.75>
      \u0422\u044B \u043F\u0440\u0430\u0432\u0434\u0430 \u0434\u0443\u043C\u0430\u0435\u0448\u044C,
      \u0447\u0442\u043E \u044F \u043F\u044B\u0442\u0430\u044E\u0441\u044C \u0442\u0435\u0431\u044F
      \u043E\u0431\u0432\u0435\u0441\u0442\u0438 \u0432\u043E\u043A\u0440\u0443\u0433
      \u043F\u0430\u043B\u044C\u0446\u0430?"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674072707080
    m_Localized: "\u0421\u043A\u043E\u043B\u044C\u043A\u043E \u0440\u0430\u0437 \u044F
      \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u043A\u0430\u043A-\u0442\u043E
      \u043D\u0430\u0432\u0440\u0435\u0434\u0438\u0442\u044C \u0442\u0435\u0431\u0435?<pause:0.75>
      \u041E\u0431\u043E\u043A\u0440\u0430\u0441\u0442\u044C?<pause:0.75> \u041F\u043E\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u044C?"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674072707081
    m_Localized: "\u041D\u0438 \u0440\u0430\u0437\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674072707082
    m_Localized: "\u0422\u043E\u0433\u0434\u0430 \u0447\u0435\u0433\u043E \u0436\u0435
      \u0442\u044B \u0436\u0434\u0435\u0448\u044C?"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674072707083
    m_Localized: "\u041F\u0430\u0440\u0442\u043D\u0435\u0440\u044B?"
    m_Metadata:
      m_Items: []
  - m_Id: 39858674072707084
    m_Localized: "<volume:0>.<pause:0.5>.<pause:0.5>.<pause:0.5><volume:1> \u041B\u0430\u0434\u043D\u043E,<pause:0.75>
