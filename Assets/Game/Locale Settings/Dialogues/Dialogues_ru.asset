    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318470
    m_Localized: "\u041D\u0430\u0434\u0435\u044E\u0441\u044C,<pause:0.5> \u0432 \u043D\u0435\u043C
      \u0431\u0443\u0434\u0435\u0442 \u043C\u043E\u0440\u0441\u043A\u0430\u044F \u0437\u0432\u0435\u0437\u0434\u0430..."
    m_Metadata:
      m_Items: []
  - m_Id: 39858674064318471
    m_Localized: "\u0419\u0430\u0440\u0440,<pause:0.75> \u043A\u043E\u043D\u0435\u0447\u043D\u043E,
      \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0439!<pause:0.75> \u041D\u043E
